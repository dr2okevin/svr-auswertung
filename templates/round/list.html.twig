{% extends 'base.html.twig' %}

{% block title %}Runden{% endblock %}

{% block body %}
    <h1>Runden für {{ competition.name }}</h1>

    <p>
        <a href="{{ path('rounds_new') }}" class="btn">Neue Runde anlegen</a>
    </p>

    {% if rounds is empty %}
        <p>Keine Runden vorhanden.</p>
    {% else %}
        <table>
            <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Start</th>
                <th>Ende</th>
                <th>Aktionen</th>
            </tr>
            </thead>
            <tbody>
            {% for round in rounds %}
                <tr>
                    <td>{{ round.id }}</td>
                    <td>{{ round.name }}</td>
                    <td>{{ round.startDate ? round.startDate|date('d.m.Y H:i') : '' }}</td>
                    <td>{{ round.endDate ? round.endDate|date('d.m.Y H:i') : '' }}</td>
                    <td>
                        <a href="{{ path('rounds_edit', {id: round.id}) }}" class="btn">Bearbeiten</a>
                        {% include 'round/_delete_form.html.twig' with {round: round} %}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
