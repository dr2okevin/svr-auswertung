{% extends 'base.html.twig' %}

{% block title %}SVR Auswertung - Verwaltung{% endblock %}

{% block body %}
    <main class="page">
        <header class="hero">
            <h1>Verwaltung</h1>
            <p>
                Einheitliche Erfassung und Pflege von Stammdaten. Die Struktur ist als Grundlage gedacht,
                damit später weitere Eigenschaften pro Datensatz ohne Bruch im Bedienkonzept ergänzt werden können.
            </p>
        </header>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash flash-{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <section class="entity-section card card-wide">
            <h2>Wettkämpfe</h2>
            <form method="post" action="{{ path('app_competition_create') }}" class="entity-create-form">
                <input type="text" name="name" required maxlength="255" placeholder="Name">
                <select name="type" required>
                    <option value="">Typ wählen</option>
                    {% for competitionType in competitionTypes %}
                        <option value="{{ competitionType.value }}">{{ competitionType.label }}</option>
                    {% endfor %}
                </select>
                <input type="datetime-local" name="start_time" required>
                <input type="datetime-local" name="end_time" required>
                <button type="submit">Anlegen</button>
            </form>

            {% if competitions is empty %}
                <p>Noch keine Wettkämpfe vorhanden.</p>
            {% else %}
                <div class="entity-list">
                    {% for competition in competitions %}
                        <div class="entity-item">
                            <form method="post" action="{{ path('app_competition_edit', {id: competition.id}) }}" class="entity-edit-form cols-4">
                                <input type="text" name="name" value="{{ competition.name }}" required maxlength="255">
                                <select name="type" required>
                                    {% for competitionType in competitionTypes %}
                                        <option value="{{ competitionType.value }}" {{ competition.type == competitionType ? 'selected' : '' }}>{{ competitionType.label }}</option>
                                    {% endfor %}
                                </select>
                                <input type="datetime-local" name="start_time" value="{{ competition.startTime|date('Y-m-d\\TH:i') }}" required>
                                <input type="datetime-local" name="end_time" value="{{ competition.endTime|date('Y-m-d\\TH:i') }}" required>
                                <button type="submit">Speichern</button>
                            </form>
                            <form method="post" action="{{ path('app_competition_delete', {id: competition.id}) }}" class="entity-delete-form">
                                <button type="submit" class="button-danger">Löschen</button>
                            </form>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        <section class="entity-section card card-wide">
            <h2>Schützen</h2>
            <form method="post" action="{{ path('app_person_create') }}" class="entity-create-form cols-4">
                <input type="text" name="first_name" required maxlength="255" placeholder="Vorname">
                <input type="text" name="last_name" required maxlength="255" placeholder="Nachname">
                <input type="date" name="birthdate">
                <label class="checkbox inline-checkbox">
                    <input type="checkbox" name="professional" value="1">
                    Profi
                </label>
                <button type="submit">Anlegen</button>
            </form>

            {% if people is empty %}
                <p>Noch keine Schützen vorhanden.</p>
            {% else %}
                <div class="entity-list">
                    {% for person in people %}
                        <div class="entity-item">
                            <form method="post" action="{{ path('app_person_edit', {id: person.id}) }}" class="entity-edit-form cols-4">
                                <input type="text" name="first_name" value="{{ person.fristName }}" required maxlength="255">
                                <input type="text" name="last_name" value="{{ person.lastName }}" required maxlength="255">
                                <input type="date" name="birthdate" value="{{ person.birthdate ? person.birthdate|date('Y-m-d') : '' }}">
                                <label class="checkbox inline-checkbox">
                                    <input type="checkbox" name="professional" value="1" {{ person.professional ? 'checked' : '' }}>
                                    Profi
                                </label>
                                <button type="submit">Speichern</button>
                            </form>
                            <form method="post" action="{{ path('app_person_delete', {id: person.id}) }}" class="entity-delete-form">
                                <button type="submit" class="button-danger">Löschen</button>
                            </form>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        <section class="entity-section card card-wide">
            <h2>Teams</h2>
            <form method="post" action="{{ path('app_team_create') }}" class="entity-create-form">
                <input type="text" name="name" required maxlength="255" placeholder="Name">
                <select name="type" required>
                    <option value="">Typ wählen</option>
                    {% for teamType in teamTypes %}
                        <option value="{{ teamType.value }}">{{ teamType.label }}</option>
                    {% endfor %}
                </select>
                <button type="submit">Anlegen</button>
            </form>

            {% if teams is empty %}
                <p>Noch keine Teams vorhanden.</p>
            {% else %}
                <div class="entity-list">
                    {% for team in teams %}
                        <div class="entity-item">
                            <form method="post" action="{{ path('app_team_edit', {id: team.id}) }}" class="entity-edit-form">
                                <input type="text" name="name" value="{{ team.name }}" required maxlength="255">
                                <select name="type" required>
                                    {% for teamType in teamTypes %}
                                        <option value="{{ teamType.value }}" {{ team.type == teamType ? 'selected' : '' }}>{{ teamType.label }}</option>
                                    {% endfor %}
                                </select>
                                <button type="submit">Speichern</button>
                            </form>
                            <form method="post" action="{{ path('app_team_delete', {id: team.id}) }}" class="entity-delete-form">
                                <button type="submit" class="button-danger">Löschen</button>
                            </form>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}
