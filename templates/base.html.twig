<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}SVR Auswertung{% endblock %}</title>
    <link rel="icon" type="image/svg" href="{{ asset('favicon.svg') }}">

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}
</head>
<body>
<div class="app-shell">
    <aside class="app-sidebar">
        {% set currentRoute = app.request.attributes.get('_route') %}
        <div class="app-brand">
            {% set competitionContext = competition_context() %}
            {# 1. Die Competition sicher holen (oder null, falls ID leer oder nicht vorhanden) #}
            {% set selectedComp = competitionContext.competitions[competitionContext.selectedCompetitionId] ?? null %}

            {# 2. Nur wenn selectedComp existiert, den Typen holen, sonst ein Fallback (z.B. 'None') #}
            {% set selectedCompetitionType = selectedComp ? selectedComp.type.name|capitalize : 'None' %}

            {# 3. Den Icon-Namen setzen (kann jetzt direkt den Typ übernehmen) #}
            {% set iconName = selectedCompetitionType %}
            {% set hasSelectedCompetition = competitionContext.selectedCompetitionId is not null %}
            <div class="app-competition__logo">
                <img src="{{ asset('icon/Competition' ~ iconName ~ '.svg') }}"  title="{{ selectedCompetitionType }}"/>
            </div>
            <div class="app-brand__text">
                <form class="app-brand__competition-form" method="get" action="{{ path('competition_context_switch') }}">
                    <select
                        class="app-brand__competition-select"
                        id="active-competition"
                        name="competition_id"
                        onchange="this.form.submit()"
                    >
                        <option value="">Wettkampf wählen</option>
                        {% for competition in competitionContext.competitions %}
                            <option
                                value="{{ competition.id }}"
                                {% if competition.id == competitionContext.selectedCompetitionId %}selected{% endif %}
                            >
                                {{ competition.name }}
                            </option>
                        {% endfor %}
                    </select>
                </form>
            </div>
        </div>

        <nav class="app-nav" aria-label="Hauptnavigation">
            <div class="app-nav__group">
                <a class="app-nav__link{% if currentRoute == 'welcome' %} app-nav__link--active{% endif %}" href="{{ path('welcome') }}">
                    <span class="app-nav__icon"><img src="{{ asset('icon/Dashboard.svg') }}" alt="" /></span>
                    <span>Dashboard</span>
                </a>

                <div class="app-nav__label">Stammdaten</div>

                <a class="app-nav__link{% if currentRoute starts with 'competitions_' %} app-nav__link--active{% endif %}" href="{{ path('competitions_list') }}">
                    <span class="app-nav__icon"><img src="{{ asset('icon/Competitions.svg') }}" alt="" /></span>
                    <span>Wettkämpfe</span>
                </a>

                <a class="app-nav__link{% if currentRoute starts with 'clubs_' %} app-nav__link--active{% endif %}" href="{{ path('clubs_list') }}">
                    <span class="app-nav__icon"><img src="{{ asset('icon/Clubs.svg') }}" alt="" /></span>
                    <span>Vereine</span>
                </a>

                <a class="app-nav__link{% if currentRoute starts with 'persons_' %} app-nav__link--active{% endif %}" href="{{ path('persons_list') }}">
                    <span class="app-nav__icon"><img src="{{ asset('icon/Persons.svg') }}" alt="" /></span>
                    <span>Personen</span>
                </a>

                <a class="app-nav__link{% if currentRoute starts with 'disciplines_' %} app-nav__link--active{% endif %}" href="{{ path('disciplines_list') }}">
                    <span class="app-nav__icon"><img src="{{ asset('icon/Discipline.svg') }}" alt="" /></span>
                    <span>Disziplinen</span>
                </a>
            </div>

            <div class="app-nav__group">
                <div class="app-nav__label">Wettkampf</div>

                {% if hasSelectedCompetition %}
                    <a class="app-nav__link{% if currentRoute starts with 'teams_' %} app-nav__link--active{% endif %}" href="{{ path('teams_list') }}">
                        <span class="app-nav__icon"><img src="{{ asset('icon/Teams.svg') }}" alt="" /></span>
                        <span>Teams</span>
                    </a>

                    {% if selectedComp and selectedComp.type and selectedComp.type.value == 'rounds' %}
                        <a class="app-nav__link{% if currentRoute starts with 'rounds_' %} app-nav__link--active{% endif %}" href="{{ path('rounds_list') }}">
                            <span class="app-nav__icon"><img src="{{ asset('icon/CompetitionRounds.svg') }}" alt="" /></span>
                            <span>Runden</span>
                        </a>
                    {% endif %}

                    <a class="app-nav__link{% if currentRoute starts with 'shots_' %} app-nav__link--active{% endif %}" href="{{ path('shots_person_list') }}">
                        <span class="app-nav__icon"><img src="{{ asset('icon/Shoots.svg') }}" alt="" /></span>
                        <span>Schüsse</span>
                    </a>

                {% endif %}
            </div>

            <div class="app-nav__group">
                <div class="app-nav__label">Auswertung</div>

                {% if hasSelectedCompetition %}
                    <a class="app-nav__link" href="#">
                        <span class="app-nav__icon"><img src="{{ asset('icon/Results.svg') }}" alt="" /></span>
                        <span>Ergebnisse</span>
                    </a>

                    <a class="app-nav__link" href="#">
                        <span class="app-nav__icon"><img src="{{ asset('icon/Export.svg') }}" alt="" /></span>
                        <span>Export</span>
                    </a>
                {% endif %}
            </div>
        </nav>
    </aside>

    <div class="app-main">
        <header class="app-header">
            <div class="app-header__left">
                <h1 class="app-page-title">{% block page_title %}Dashboard{% endblock %}</h1>
                <div class="app-breadcrumbs">
                    {% block breadcrumbs %}
                        <span>SVR Auswertung</span>
                    {% endblock %}
                </div>
            </div>

            <div class="app-header__right">
                {% block page_actions %}{% endblock %}

                <details class="profile-menu">
                    <summary class="profile-menu__trigger">
                                <span class="profile-menu__avatar">
                                    {{ app.user and app.user.email ? app.user.email|first|upper : 'U' }}
                                </span>
                        <span class="profile-menu__meta">
                                    <strong>{{ app.user and app.user.email ? app.user.email : 'Profil' }}</strong>
                                    <small>Benutzerkonto</small>
                                </span>
                    </summary>

                    <div class="profile-menu__dropdown">
                        <a href="#" class="profile-menu__item">Profil</a>
                        <a href="#" class="profile-menu__item">Einstellungen</a>
                        <hr class="profile-menu__divider">
                        <a href="#" class="profile-menu__item">Abmelden</a>
                    </div>
                </details>
            </div>
        </header>

        <main class="app-content">
            {% block body %}
                <section class="panel">
                    <div class="panel__header">
                        <h2 class="panel__title">Willkommen</h2>
                    </div>

                    <div class="panel__body">
                        Inhalt
                    </div>
                </section>
            {% endblock %}
        </main>
    </div>
</div>

{% block javascripts %}{% endblock %}
</body>
</html>
