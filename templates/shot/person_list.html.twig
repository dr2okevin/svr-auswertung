{% extends 'base.html.twig' %}

{% block title %}Schüsse{% endblock %}

{% block body %}
    <h1>Schüsse für {{ competition.name }}</h1>

    <p><a href="{{ path('shots_disag_import') }}" class="btn">DISAG XML importieren</a></p>

    {% if rounds is empty %}
        <p>Für den ausgewählten Wettkampf sind keine Runden vorhanden.</p>
    {% else %}
        <form method="get" action="{{ path('shots_person_list') }}">
            <label for="round">Runde:</label>
            <select name="round" id="round" onchange="this.form.submit()">
                {% for round in rounds %}
                    <option value="{{ round.id }}" {% if selectedRound and round.id == selectedRound.id %}selected{% endif %}>
                        {{ round.name }}
                    </option>
                {% endfor %}
            </select>
            <noscript><button type="submit" class="btn">Anzeigen</button></noscript>
        </form>

        {% if selectedRound %}
            <h2>{{ selectedRound.name }}</h2>

            {% if seriesByDiscipline is empty %}
                <p>Für diese Runde sind noch keine Serien vorhanden.</p>
            {% else %}
                {% for disciplineName, seriesEntries in seriesByDiscipline %}
                    <table>
                        <thead>
                        <tr>
                            <th colspan="5">{{ disciplineName }}</th>
                        </tr>
                        <tr>
                            <th>Person</th>
                            <th>Disziplin</th>
                            <th>Team</th>
                            <th>Schüsse</th>
                            <th>Aktionen</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for entry in seriesEntries %}
                            <tr>
                                <td>{{ entry.personName }}</td>
                                <td>{{ entry.disciplineName }}</td>
                                <td>{{ entry.teamName }}</td>
                                <td>{{ entry.shotCount }}/{{ entry.totalShots }}</td>
                                <td>
                                    {% if entry.series %}
                                        <a href="{{ path('shots_series_edit', {id: entry.series.id}) }}" class="btn">Bearbeiten</a>
                                    {% else %}
                                        <a href="{{ path('shots_series_open', {round: selectedRound.id, teamMember: entry.teamMember.id}) }}" class="btn">Schüsse eintragen</a>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                {% endfor %}
            {% endif %}
        {% endif %}
    {% endif %}
{% endblock %}
