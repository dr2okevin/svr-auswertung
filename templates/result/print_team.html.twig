<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Teamwertung drucken – {{ competition.name }}</title>
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
</head>
<body>
<main class="app-content" style="max-width: 1200px; margin: 0 auto;">
    <div class="toolbar print-toolbar" style="margin-bottom: 16px;">
        <button type="button" class="btn btn--primary" onclick="window.print()">Jetzt drucken</button>
        <a class="btn" href="{{ path('results_export_team_csv') }}">CSV Teamwertung</a>
        <a class="btn" href="{{ path('results_index') }}">Zurück zur Auswertung</a>
    </div>

    <h1>Teamwertung – {{ competition.name }}</h1>

    <section class="panel" style="margin-bottom: 20px;">
        <div class="panel__header">
            <h2 class="panel__title">Gesamtliste Teams</h2>
        </div>
        <div class="panel__body">
            {% if teamRanking is empty %}
                <p>Keine Teamdaten vorhanden.</p>
            {% else %}
                <table>
                    <thead>
                    <tr>
                        <th>Platz</th>
                        <th>Team</th>
                        <th>Typ</th>
                        <th>Ringe</th>
                        <th>Wertungen</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for team in teamRanking %}
                        <tr>
                            <td>{{ team.rank }}</td>
                            <td>{{ team.teamName }}</td>
                            <td>{{ team.teamType }}</td>
                            <td>{{ team.totalScore|number_format(1, ',', '.') }}</td>
                            <td>{{ team.scoredAssignments }}/{{ team.expectedAssignments }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    </section>
</main>
</body>
</html>
