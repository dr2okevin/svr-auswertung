<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Teamwertung drucken – {{ competition.name }}</title>
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
</head>
<body>
<main class="app-content print-page">
    <div class="toolbar print-toolbar">
        <button type="button" class="btn btn--primary" onclick="window.print()">Jetzt drucken</button>
        <a class="btn" href="{{ path('results_export_team_csv') }}">CSV Teamwertung</a>
        <a class="btn" href="{{ path('results_index') }}">Zurück zur Auswertung</a>
    </div>

    <section class="print-sheet print-sheet--team">
        <header class="print-heading">
            <p class="print-heading__club">{{ print_header_club_name }}</p>
            <h1 class="print-heading__title">{{ competition.name }}</h1>
            <h2 class="print-heading__subtitle">Mannschaftswertung</h2>
        </header>

        <div class="print-table-wrap">
            {% if teamRanking is empty %}
                <p>Keine Teamdaten vorhanden.</p>
            {% else %}
                <table class="print-results-table">
                    <thead>
                    <tr>
                        <th>Platz</th>
                        <th>Team</th>
                        <th>Namen</th>
                        {% for discipline in competition.disciplines %}
                            <th>{{ discipline.name }}</th>
                        {% endfor %}
                        <th>Ergebnis</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for team in teamRanking %}
                        <tr>
                            <td>{{ team.rank }}</td>
                            <td>{{ team.teamName }}</td>
                            <td>
                                {% set shownIds = [] %}
                                {% for teamMember in team.teamMembers %}
                                    {# Prüfen, ob die Person bereits in diesem Team-Block angezeigt wurde #}
                                    {% if teamMember.person.id not in shownIds %}
                                        {# Formatierung: Erster Buchstabe . Nachname #}
                                        <span class="name">{{ teamMember.person.FristName|slice(0, 1) }}. {{ teamMember.person.lastName }}</span>

                                        {# ID zum Array hinzufügen, um Dopplungen zu vermeiden #}
                                        {% set shownIds = shownIds|merge([teamMember.person.id]) %}
                                    {% endif %}
                                {% endfor %}
                            </td>
                            {% for discipline in competition.disciplines %}
                                <td>{{ team.disciplineScores[discipline.id]|default(0)|number_format(1, ',', '.') }}</td>
                            {% endfor %}
                            <td>{{ team.totalScore|number_format(1, ',', '.') }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            {% endif %}
        </div>
    </section>
</main>
</body>
</html>
