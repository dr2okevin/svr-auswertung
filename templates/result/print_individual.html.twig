<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ competition.name }} - Einzelwertung – {{ discipline.disciplineName }}</title>
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
</head>
<body>
<main class="app-content print-page">
    <div class="toolbar print-toolbar">
        <button type="button" class="btn btn--primary" onclick="window.print()">Jetzt drucken</button>
        <a class="btn" href="{{ path('results_export_individual_csv', { disciplineId: discipline.disciplineId }) }}">CSV Einzelwertung</a>
        <a class="btn" href="{{ path('results_index') }}">Zurück zur Auswertung</a>
    </div>

    <section class="print-sheet print-sheet--individual">
        <header class="print-heading">
            <p class="print-heading__club">{{ print_header_club_name }}</p>
            <h1 class="print-heading__title">{{ competition.name }}</h1>
            <h2 class="print-heading__subtitle">Einzelwertung</h2>
            <h3 class="print-heading__discipline">{{ discipline.disciplineName }}</h3>
        </header>

        <div class="print-table-wrap">
            <table class="print-results-table">
                <thead>
                <tr>
                    <th>Platz</th>
                    <th>Name</th>
                    <th>Team</th>
                    <th>Ringe</th>
                </tr>
                </thead>
                <tbody>
                {% for entry in discipline.entries %}
                    <tr>
                        <td>{{ entry.rank }}</td>
                        <td><span class="name">{{ entry.personFirstName|slice(0, 1) }}. {{ entry.personLastName }}</span></td>
                        <td>{{ entry.teamName }}</td>
                        <td>{{ entry.totalScore|number_format(1, ',', '.') }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
</main>
</body>
</html>
