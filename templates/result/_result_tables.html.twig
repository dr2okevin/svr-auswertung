{% if not isFireOrCompanyCompetition %}
    <p><strong>Hinweis:</strong> Diese Ansicht ist primär für Feuerwehr- und Betriebeschießen ausgelegt, keine Garantie auf korrekte Funktion für andere Wettkampf-Typen.</p>
{% endif %}

<section class="panel" style="margin-bottom: 20px;">
    <div class="panel__header">
        <h2 class="panel__title">Gesamtliste Teams</h2>
        {% if showActions|default(false) %}
            <div class="toolbar">
                <a class="btn btn--primary" href="{{ path('results_export_team_csv') }}">CSV Teamwertung</a>
                <a class="btn" href="{{ path('results_print_team') }}" target="_blank" rel="noopener">Druck Teamwertung</a>
            </div>
        {% endif %}
    </div>
    <div class="panel__body">
        {% if teamRanking is empty %}
            <p>Keine Teamdaten vorhanden.</p>
        {% else %}
            <table>
                <thead>
                <tr>
                    <th>Platz</th>
                    <th>Team</th>
                    <th>Typ</th>
                    <th>Ringe</th>
                    <th>Wertungen</th>
                </tr>
                </thead>
                <tbody>
                {% for team in teamRanking %}
                    <tr>
                        <td>{{ team.rank }}</td>
                        <td>{{ team.teamName }}</td>
                        <td>{{ team.teamType }}</td>
                        <td>{{ team.totalScore|number_format(1, ',', '.') }}</td>
                        <td>{{ team.scoredAssignments }}/{{ team.expectedAssignments }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</section>

{% if individualByDiscipline is empty %}
    <p>Es liegen noch keine Einzelergebnisse vor.</p>
{% else %}
    {% for discipline in individualByDiscipline %}
        <section class="panel" style="margin-bottom: 20px; page-break-inside: avoid;">
            <div class="panel__header">
                <h2 class="panel__title">Bestenliste Einzelschützen – {{ discipline.disciplineName }}</h2>
                {% if showActions|default(false) %}
                    <div class="toolbar">
                        <a class="btn btn--primary" href="{{ path('results_export_individual_csv', { disciplineId: discipline.disciplineId }) }}">CSV Einzelwertung</a>
                        <a class="btn" href="{{ path('results_print_individual', { disciplineId: discipline.disciplineId }) }}" target="_blank" rel="noopener">Druck Einzelwertung</a>
                    </div>
                {% endif %}
            </div>
            <div class="panel__body">
                <table>
                    <thead>
                    <tr>
                        <th>Platz</th>
                        <th>Schütze</th>
                        <th>Team</th>
                        <th>Status</th>
                        <th>Ringe</th>
                        <th>Schüsse</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for entry in discipline.entries %}
                        <tr>
                            <td>{{ entry.rank }}</td>
                            <td>{{ entry.personName }}</td>
                            <td>{{ entry.teamName }}</td>
                            <td>{% if entry.isProfessional %}Profi{% else %}Amateur{% endif %}</td>
                            <td>{{ entry.totalScore|number_format(1, ',', '.') }}</td>
                            <td>{{ entry.shotCount }}/{{ entry.targetShotCount }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </section>
    {% endfor %}
{% endif %}
