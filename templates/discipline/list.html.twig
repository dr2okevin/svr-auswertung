{% extends 'base.html.twig' %}

{% block title %}Disziplinen{% endblock %}

{% block body %}
    <h1>Disziplinen</h1>

    <p>
        <a href="{{ path('disciplines_new') }}" class="btn">Neue Disziplin anlegen</a>
    </p>

    {% if disciplines is empty %}
        <p>Keine Disziplinen vorhanden.</p>
    {% else %}
        <table>
            <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Schüsse je Serie</th>
                <th>Max. Anzahl Serien</th>
                <th>Wertungsmodus</th>
                <th>Max. Punktzahl je Schuss</th>
                <th>Aktionen</th>
            </tr>
            </thead>
            <tbody>
            {% for discipline in disciplines %}
                <tr>
                    <td>{{ discipline.id }}</td>
                    <td>{{ discipline.name }}</td>
                    <td>{{ discipline.shotsPerSeries }}</td>
                    <td>{{ discipline.maxSeriesCount }}</td>
                    <td>{{ discipline.scoringMode ? discipline.scoringMode.getLabel() : '' }}</td>
                    <td>{{ discipline.maxScoresPerShot }}</td>
                    <td>
                        <a href="{{ path('disciplines_show', {id: discipline.id}) }}" class="btn">Anzeigen</a>
                        <a href="{{ path('disciplines_edit', {id: discipline.id}) }}" class="btn">Bearbeiten</a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    {% endif %}
{% endblock %}
